client/.vite/
client/.next/
client/.nuxt/

# --- BACKEND SPECIFIC (R1/python-backend) ---
python-backend/*.py[cod]
python-backend/.python-version

# --- SYSTEM & LOGS ---
**/*.log
**/*.db
**/*.sqlite*
.DS_Store
Thumbs.db
.manus-logs/
screenshots/

